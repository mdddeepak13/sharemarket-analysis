# ============================================
# ShareMarket Analysis - Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Polygon.io (https://polygon.io)
POLYGON_API_KEY=your_polygon_api_key_here

# Anthropic / Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pinecone (https://pinecone.io)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=sharmarket-rag

# Neon PostgreSQL (provision via Vercel Marketplace)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Upstash Redis (provision via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Finnhub (https://finnhub.io - free tier)
FINNHUB_API_KEY=your_finnhub_api_key_here

# FRED API (https://fred.stlouisfed.org/docs/api - free)
FRED_API_KEY=your_fred_api_key_here

# n8n (https://n8n.io)
N8N_WEBHOOK_SECRET=generate_a_random_secret_here
N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud

# Auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ShareMarket Analysis
